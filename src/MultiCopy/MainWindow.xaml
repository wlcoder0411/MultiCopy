<Window x:Class="MultiCopy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MultiCopy.Models"
        xmlns:infra="clr-namespace:MultiCopy.Infrastructure"
        Title="MultiCopy"
        Width="384" Height="560"
        MinWidth="320" MinHeight="360"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="Manual"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        Closing="Window_Closing">
    <Window.Resources>
        <infra:AlternationIndexConverter x:Key="IdxConv" />
        <BooleanToVisibilityConverter x:Key="Bool2Vis" />

        <!-- 普通项：单击粘贴并移除（扁平区/未分组区/分组内均复用） -->
        <DataTemplate x:Key="NormalItemTemplate" DataType="{x:Type models:ClipboardItem}">
            <Border x:Name="card" Margin="8,3" Padding="8,6"
                    Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6"
                    Cursor="Hand"
                    MouseLeftButtonDown="NormalItem_Click"
                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                <Border.ContextMenu>
                    <!-- 右键弹出。WPF 右键不触发 MouseLeftButtonDown，故不会触发粘贴。
                         子菜单"移动到分组…"在 Opened 事件中动态构建，实时反映当前分组。 -->
                    <ContextMenu Opened="ItemContextMenu_Opened">
                        <MenuItem x:Name="MoveMenu" Header="移动到分组…"
                                  ToolTip="将此项移到其他分组"/>
                        <Separator/>
                        <MenuItem Header="置顶"
                                  Command="{Binding PlacementTarget.Tag.PinCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="删除"
                                  Command="{Binding PlacementTarget.Tag.DeleteNormalCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="{DynamicResource ForegroundDimBrush}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Text="{Binding (ItemsControl.AlternationIndex),
                                      RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                      Converter={StaticResource IdxConv}}" />

                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="4,0,8,0"
                               Text="{Binding Preview}" ToolTip="{Binding Text}"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButton}" ToolTip="置顶"
                                Command="{Binding DataContext.PinCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconPin}"/>
                        </Button>
                        <Button Style="{StaticResource GhostButton}" ToolTip="删除"
                                Command="{Binding DataContext.DeleteNormalCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconClose}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <Trigger SourceName="card" Property="IsMouseOver" Value="True">
                    <Setter TargetName="card" Property="Background" Value="{DynamicResource CardBackgroundHoverBrush}" />
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- 置顶项：双击粘贴并保留 -->
        <DataTemplate x:Key="PinnedItemTemplate" DataType="{x:Type models:ClipboardItem}">
            <Border x:Name="card" Margin="8,3" Padding="8,6"
                    Background="{DynamicResource PinBackgroundBrush}" CornerRadius="6"
                    BorderBrush="{DynamicResource PinBrush}" BorderThickness="2,0,0,0"
                    Cursor="Hand"
                    MouseLeftButtonDown="PinnedItem_DoubleClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="{DynamicResource PinBrush}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Text="{Binding (ItemsControl.AlternationIndex),
                                      RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                      Converter={StaticResource IdxConv}}" />

                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="4,0,8,0"
                               Text="{Binding Preview}" ToolTip="双击粘贴（保留）"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButton}" ToolTip="取消置顶"
                                Command="{Binding DataContext.UnpinCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconPin}"
                                  Stroke="{DynamicResource PinBrush}" Fill="{DynamicResource PinBrush}"/>
                        </Button>
                        <Button Style="{StaticResource GhostButton}" ToolTip="删除"
                                Command="{Binding DataContext.DeletePinnedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconClose}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <Trigger SourceName="card" Property="IsMouseOver" Value="True">
                    <Setter TargetName="card" Property="Background" Value="{DynamicResource PinBackgroundHoverBrush}" />
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- 普通图片项：单击粘贴并移除（结构与 NormalItemTemplate 对称，新增 96×96 缩略图列） -->
        <DataTemplate x:Key="ImageNormalItemTemplate" DataType="{x:Type models:ImageClipboardItem}">
            <Border x:Name="card" Margin="8,3" Padding="8,6"
                    Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6"
                    Cursor="Hand"
                    MouseLeftButtonDown="NormalItem_Click"
                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                <Border.ContextMenu>
                    <ContextMenu Opened="ItemContextMenu_Opened">
                        <MenuItem x:Name="MoveMenu" Header="移动到分组…"
                                  ToolTip="将此项移到其他分组"/>
                        <Separator/>
                        <MenuItem Header="置顶"
                                  Command="{Binding PlacementTarget.Tag.PinCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="删除"
                                  Command="{Binding PlacementTarget.Tag.DeleteNormalCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="104" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 序号（与 NormalItemTemplate 一致） -->
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="{DynamicResource ForegroundDimBrush}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Text="{Binding (ItemsControl.AlternationIndex),
                                      RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                      Converter={StaticResource IdxConv}}" />

                    <!-- 96×96 缩略图（Border 固定背景色，防亮色主题透白边；UniformToFill 居中裁剪） -->
                    <Border Grid.Column="1" Width="96" Height="96" Margin="4,0"
                            Background="{DynamicResource ThumbnailBackgroundBrush}"
                            CornerRadius="4" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" Width="96" Height="96"/>
                    </Border>

                    <!-- 副标题：截图 WxH + 来源应用 -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,8,0">
                        <TextBlock Text="{Binding Preview}" FontWeight="Medium"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                        <TextBlock Text="{Binding SourceApp}" Margin="0,2,0,0"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{DynamicResource ForegroundDimBrush}"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                    </StackPanel>

                    <!-- 置顶 + 删除按钮（与 NormalItemTemplate 一致） -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButton}" ToolTip="置顶"
                                Command="{Binding DataContext.PinCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconPin}"/>
                        </Button>
                        <Button Style="{StaticResource GhostButton}" ToolTip="删除"
                                Command="{Binding DataContext.DeleteNormalCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconClose}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <Trigger SourceName="card" Property="IsMouseOver" Value="True">
                    <Setter TargetName="card" Property="Background" Value="{DynamicResource CardBackgroundHoverBrush}" />
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- 置顶图片项：双击粘贴并保留（结构与 PinnedItemTemplate 对称，新增 96×96 缩略图列） -->
        <DataTemplate x:Key="ImagePinnedItemTemplate" DataType="{x:Type models:ImageClipboardItem}">
            <Border x:Name="card" Margin="8,3" Padding="8,6"
                    Background="{DynamicResource PinBackgroundBrush}" CornerRadius="6"
                    BorderBrush="{DynamicResource PinBrush}" BorderThickness="2,0,0,0"
                    Cursor="Hand"
                    MouseLeftButtonDown="PinnedItem_DoubleClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="104" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 序号（与 PinnedItemTemplate 一致，PinBrush 色） -->
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="{DynamicResource PinBrush}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Text="{Binding (ItemsControl.AlternationIndex),
                                      RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                      Converter={StaticResource IdxConv}}" />

                    <!-- 96×96 缩略图 -->
                    <Border Grid.Column="1" Width="96" Height="96" Margin="4,0"
                            Background="{DynamicResource ThumbnailBackgroundBrush}"
                            CornerRadius="4" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" Width="96" Height="96"/>
                    </Border>

                    <!-- 副标题：截图 WxH + 来源应用（ToolTip 提示双击粘贴） -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,8,0"
                                ToolTip="双击粘贴（保留）">
                        <TextBlock Text="{Binding Preview}" FontWeight="Medium"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                        <TextBlock Text="{Binding SourceApp}" Margin="0,2,0,0"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{DynamicResource ForegroundDimBrush}"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                    </StackPanel>

                    <!-- 取消置顶 + 删除按钮（与 PinnedItemTemplate 一致，图钉实心填充） -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButton}" ToolTip="取消置顶"
                                Command="{Binding DataContext.UnpinCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconPin}"
                                  Stroke="{DynamicResource PinBrush}" Fill="{DynamicResource PinBrush}"/>
                        </Button>
                        <Button Style="{StaticResource GhostButton}" ToolTip="删除"
                                Command="{Binding DataContext.DeletePinnedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconClose}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <Trigger SourceName="card" Property="IsMouseOver" Value="True">
                    <Setter TargetName="card" Property="Background" Value="{DynamicResource PinBackgroundHoverBrush}" />
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- 分组模板（QQ 风格：分组头 + 可折叠组内项） -->
        <DataTemplate x:Key="GroupTemplate" DataType="{x:Type models:ClipboardGroup}">
            <StackPanel Margin="0,2">
                <!-- 分组头：箭头列单独命中折叠，其余区域单击设为活动组 -->
                <Border x:Name="header" Padding="8,5" Margin="8,4,8,2" CornerRadius="6"
                        Background="{DynamicResource CardBackgroundBrush}" Cursor="Hand"
                        MouseLeftButtonDown="GroupHeader_Click"
                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- 展开箭头（双 Path + DataTrigger，替 ExpandArrowConverter） -->
                        <Border Grid.Column="0" Background="Transparent"
                                MouseLeftButtonDown="GroupArrow_Click">
                            <Grid Width="16" Height="16">
                                <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconChevronRight}">
                                    <Path.Visibility>
                                        <Binding Path="IsExpanded" Converter="{x:Static infra:InverseBoolToVisibilityConverter.Instance}"/>
                                    </Path.Visibility>
                                </Path>
                                <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconChevronDown}"
                                      Visibility="{Binding IsExpanded, Converter={StaticResource Bool2Vis}}"/>
                            </Grid>
                        </Border>
                        <!-- 分组名 -->
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Text="{Binding Name}" />
                        <!-- 项数 -->
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="6,0,0,0"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{DynamicResource ForegroundDimBrush}">
                            <Run Text="(" /><Run Text="{Binding Items.Count, Mode=OneWay}" /><Run Text=")" />
                        </TextBlock>
                        <!-- 活动组标记（Ellipse 替 ● 文字） -->
                        <Ellipse Grid.Column="3" Width="6" Height="6" Margin="6,0,0,0"
                                 VerticalAlignment="Center"
                                 Fill="{DynamicResource AccentBrush}"
                                 Visibility="{Binding IsActiveGroup, Converter={StaticResource Bool2Vis}}" />
                    </Grid>
                    <Border.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="设为活动分组"
                                      Command="{Binding PlacementTarget.Tag.SetActiveGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="重命名"
                                      Command="{Binding PlacementTarget.Tag.RenameGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="清空组内项"
                                      Command="{Binding PlacementTarget.Tag.ClearGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <Separator />
                            <MenuItem Header="删除分组"
                                      Command="{Binding PlacementTarget.Tag.DeleteGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                    </Border.ContextMenu>
                </Border>
                <!-- 组内项（折叠时 Collapsed，无动画） -->
                <ItemsControl ItemsSource="{Binding Items}" AlternationCount="1000"
                              ScrollViewer.CanContentScroll="True"
                              Visibility="{Binding IsExpanded, Converter={StaticResource Bool2Vis}}">
                    <ItemsControl.ItemTemplateSelector>
                        <infra:ClipboardItemTemplateSelector
                            TextTemplate="{StaticResource NormalItemTemplate}"
                            ImageTemplate="{StaticResource ImageNormalItemTemplate}"/>
                    </ItemsControl.ItemTemplateSelector>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel VirtualizationMode="Recycling"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
            <DataTemplate.Triggers>
                <!-- 活动分组头部高亮 -->
                <DataTrigger Binding="{Binding IsActiveGroup}" Value="True">
                    <Setter TargetName="header" Property="Background" Value="{DynamicResource AccentBackgroundBrush}" />
                    <Setter TargetName="header" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter TargetName="header" Property="BorderThickness" Value="2,0,0,0" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部栏 -->
        <DockPanel Grid.Row="0" Margin="12,8,12,6">
            <!-- 左上角：爱心图标（点击弹收款码，无文字） -->
            <Path DockPanel.Dock="Left" Style="{StaticResource IconStyle}"
                  Data="{StaticResource IconHeart}" VerticalAlignment="Center"
                  Cursor="Hand" MouseLeftButtonDown="SupportAuthor_Click"
                  Fill="{DynamicResource AccentBrush}" Stroke="{DynamicResource AccentBrush}"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <!-- 监控开关（眼睛图标，开=睁眼，关=闭眼） -->
                <ToggleButton Style="{StaticResource GhostToggleButton}" ToolTip="监控剪贴板开关"
                              Margin="0,0,4,0"
                              IsChecked="{Binding IsMonitoring, Mode=TwoWay}">
                    <Grid Width="16" Height="16">
                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconEye}"
                              Visibility="{Binding IsMonitoring, Converter={x:Static infra:BoolToVisibilityConverter.Instance}}"/>
                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconEyeOff}">
                            <Path.Visibility>
                                <Binding Path="IsMonitoring" Converter="{x:Static infra:InverseBoolToVisibilityConverter.Instance}"/>
                            </Path.Visibility>
                        </Path>
                    </Grid>
                </ToggleButton>
                <Button Style="{StaticResource GhostButton}" ToolTip="新建分组"
                        Margin="0,0,4,0"
                        Command="{Binding CreateGroupCommand}">
                    <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconPlus}"/>
                </Button>
                <Button Style="{StaticResource GhostButton}" ToolTip="清空普通队列（含所有分组）"
                        Margin="0,0,4,0"
                        Command="{Binding ClearNormalCommand}">
                    <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconTrash}"/>
                </Button>
                <Button Style="{StaticResource GhostButton}" ToolTip="切换主题"
                        Margin="0,0,4,0"
                        Command="{Binding ToggleThemeCommand}">
                    <Grid Width="16" Height="16">
                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconSun}"
                              Visibility="{Binding IsLightTheme, Converter={x:Static infra:BoolToVisibilityConverter.Instance}}"/>
                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconMoon}">
                            <Path.Visibility>
                                <Binding Path="IsLightTheme" Converter="{x:Static infra:InverseBoolToVisibilityConverter.Instance}"/>
                            </Path.Visibility>
                        </Path>
                    </Grid>
                </Button>
                <Button Style="{StaticResource GhostButton}" ToolTip="设置"
                        Margin="0,0,4,0"
                        Click="Settings_Click">
                    <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconSettings}"/>
                </Button>
                <ToggleButton Style="{StaticResource PillButton}"
                              IsChecked="{Binding ModeOn, Mode=TwoWay}"
                              Content="{Binding ModeOn, Converter={x:Static infra:ModeLabelConverter.Instance}, Mode=OneWay}" />
            </StackPanel>
        </DockPanel>

        <Separator Grid.Row="0" VerticalAlignment="Bottom"
                   Background="{DynamicResource BorderBrush}" Margin="0,2" />

        <!-- 搜索框 -->
        <Border Grid.Row="1" Margin="12,2,12,6" Style="{StaticResource SearchBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Path Grid.Column="0" Style="{StaticResource IconStyle}"
                      Data="{StaticResource IconSearch}" Margin="8,0,6,0"/>
                <TextBox Grid.Column="1" x:Name="SearchBox"
                         Style="{StaticResource SearchTextBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                         Tag="搜索复制内容…"
                         GotFocus="SearchBox_GotFocus"
                         LostFocus="SearchBox_LostFocus" />
                <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                        Margin="2,0,2,0" Padding="4"
                        ToolTip="清空搜索（Esc）"
                        Command="{Binding ClearSearchCommand}"
                        Visibility="{Binding IsSearching, Converter={x:Static infra:BoolToVisibilityConverter.Instance}}">
                    <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconClose}"/>
                </Button>
            </Grid>
        </Border>

        <!-- 列表区 -->
        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,4">
                <StackPanel>
                    <!-- 置顶区（始终在最上，不受分组影响） -->
                    <StackPanel Visibility="{Binding PinnedEmpty, Converter={x:Static infra:InverseBoolToVisibilityConverter.Instance}, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Margin="12,8,0,2">
                            <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconPin}"
                                  Stroke="{DynamicResource PinBrush}" Fill="{DynamicResource PinBrush}"
                                  Width="13" Height="13" Margin="0,0,4,0"/>
                            <TextBlock FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource PinBrush}"
                                       Text="置顶（双击粘贴 · 不会被 Ctrl+V 消耗）" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding PinnedItems}"
                                      AlternationCount="1000"
                                      ScrollViewer.CanContentScroll="True">
                            <ItemsControl.ItemTemplateSelector>
                                <infra:ClipboardItemTemplateSelector
                                    TextTemplate="{StaticResource PinnedItemTemplate}"
                                    ImageTemplate="{StaticResource ImagePinnedItemTemplate}"/>
                            </ItemsControl.ItemTemplateSelector>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel VirtualizationMode="Recycling"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <!-- 扁平区：无分组时显示（默认状态，绑定 UngroupedItems） -->
                    <StackPanel Visibility="{Binding IsGrouping, Converter={x:Static infra:InverseBoolToVisibilityConverter.Instance}}">
                        <TextBlock Margin="12,8,0,2" FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{DynamicResource ForegroundDimBrush}"
                                   Text="队列（开模式后按 Ctrl+V 按序粘贴 · 单击直接粘贴）" />
                        <ItemsControl ItemsSource="{Binding UngroupedItems}"
                                      AlternationCount="1000"
                                      ScrollViewer.CanContentScroll="True">
                            <ItemsControl.ItemTemplateSelector>
                                <infra:ClipboardItemTemplateSelector
                                    TextTemplate="{StaticResource NormalItemTemplate}"
                                    ImageTemplate="{StaticResource ImageNormalItemTemplate}"/>
                            </ItemsControl.ItemTemplateSelector>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel VirtualizationMode="Recycling"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <!-- 分组区：有分组时显示 -->
                    <StackPanel Visibility="{Binding IsGrouping, Converter={StaticResource Bool2Vis}}">
                        <!-- 未分组项（无分组头，置顶于分组区） -->
                        <StackPanel Visibility="{Binding UngroupedEmpty, Converter={x:Static infra:InverseBoolToVisibilityConverter.Instance}}">
                            <TextBlock Margin="12,8,0,2" FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource ForegroundDimBrush}"
                                       Text="未分组（单击粘贴 · 开模式 Ctrl+V 按序出队）" />
                            <ItemsControl ItemsSource="{Binding UngroupedItems}"
                                          AlternationCount="1000"
                                          ScrollViewer.CanContentScroll="True">
                                <ItemsControl.ItemTemplateSelector>
                                    <infra:ClipboardItemTemplateSelector
                                        TextTemplate="{StaticResource NormalItemTemplate}"
                                        ImageTemplate="{StaticResource ImageNormalItemTemplate}"/>
                                </ItemsControl.ItemTemplateSelector>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel VirtualizationMode="Recycling"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                        <!-- 各分组 -->
                        <ItemsControl ItemsSource="{Binding Groups}"
                                      ItemTemplate="{StaticResource GroupTemplate}" />
                    </StackPanel>

                    <!-- 空状态 -->
                    <StackPanel Margin="0,40,0,0" HorizontalAlignment="Center"
                                Visibility="{Binding AllEmpty, Converter={StaticResource Bool2Vis}}">
                        <!-- 搜索无结果 -->
                        <StackPanel Visibility="{Binding SearchNoResult, Converter={x:Static infra:BoolToVisibilityConverter.Instance}}">
                            <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconSearch}"
                                  Width="32" Height="32" HorizontalAlignment="Center"
                                  StrokeThickness="1.5"/>
                            <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource ForegroundDimBrush}">
                                <Run Text="未找到匹配「"/><Run Text="{Binding SearchText}"/><Run Text="」的条目"/>
                            </TextBlock>
                        </StackPanel>
                        <!-- 队列空（无搜索） -->
                        <StackPanel Visibility="{Binding IsSearching, Converter={x:Static infra:InverseBoolToVisibilityConverter.Instance}}">
                            <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconInbox}"
                                  Width="32" Height="32" HorizontalAlignment="Center"
                                  StrokeThickness="1.5"/>
                            <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource ForegroundDimBrush}"
                                       Text="暂无复制内容" />
                            <TextBlock Margin="0,4,0,0" HorizontalAlignment="Center"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource ForegroundDimBrush}"
                                       Text="在任意应用按 Ctrl+C 即可收集到这里" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 底部提示 -->
        <Border Grid.Row="3" Background="{DynamicResource CardBackgroundBrush}" Padding="12,8">
            <TextBlock FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{DynamicResource ForegroundDimBrush}" TextWrapping="Wrap">
                <Run Text="模式开：Ctrl+V 按序出队 · 选中分组时仅出该分组 · 按住 Shift 临时用普通粘贴" />
                <LineBreak />
                <Run Text="单击普通项粘贴 · 双击置顶项粘贴(保留) · 搜索框输入即过滤 · Esc 清空搜索" />
            </TextBlock>
        </Border>
    </Grid>
</Window>
